{
  "name": "totonoe-knowledge",
  "displayName": "Totonoe Knowledge",
  "description": "調査や会話を、検索・再利用できるMarkdownナレッジへ整えるVS Code拡張",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/upu/Totonoe-Knowledge.git"
  },
  "files": [
    "dist/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "publisher": "totonoe",
  "engines": {
    "vscode": "^1.95.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "ナレッジの読み書きとLanguage Model Toolを使用するため、信頼済みワークスペースでのみ有効化します。"
    }
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "totonoeKnowledge.registerFromClipboard",
        "title": "Totonoe Knowledge: Register from Clipboard"
      },
      {
        "command": "totonoeKnowledge.registerSelection",
        "title": "Totonoe Knowledge: Register Selection"
      },
      {
        "command": "totonoeKnowledge.search",
        "title": "Totonoe Knowledge: Search"
      },
      {
        "command": "totonoeKnowledge.validateRepository",
        "title": "Totonoe Knowledge: Validate Repository"
      },
      {
        "command": "totonoeKnowledge.rebuildSearchIndex",
        "title": "Totonoe Knowledge: Rebuild Search Index"
      }
    ],
    "languageModelTools": [
      {
        "name": "totonoe-knowledge_saveKnowledge",
        "displayName": "Save Totonoe Knowledge",
        "toolReferenceName": "totonoeKnowledgeSave",
        "canBeReferencedInPrompt": true,
        "icon": "$(book)",
        "userDescription": "会話で整理した内容を確認付きでMarkdownナレッジとして保存します。",
        "modelDescription": "Save a structured internal project knowledge entry as Markdown. Use when the user explicitly asks to record a conclusion, investigation, procedure, decision, specification, change, or troubleshooting result. The tool always asks the user for confirmation before writing. Do not use it for temporary notes or when required facts are still unknown.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "description": "Specific title that identifies the knowledge later"
            },
            "summary": {
              "type": "string",
              "description": "One-sentence conclusion"
            },
            "type": {
              "type": "string",
              "enum": [
                "investigation",
                "troubleshooting",
                "specification",
                "change",
                "procedure",
                "decision"
              ]
            },
            "keywords": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "conclusion": {
              "type": "string"
            },
            "background": {
              "type": "string"
            },
            "verified": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "procedure": {
              "type": "string"
            },
            "cautions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "unresolved": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "relatedKnowledgeIds": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Existing related knowledge IDs; omit rather than guess"
            },
            "supersedesKnowledgeIds": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Older knowledge IDs explicitly replaced by this entry; omit rather than guess"
            },
            "sourceReferences": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Relevant files, issues, commits, or document references"
            }
          },
          "required": [
            "title",
            "summary",
            "type",
            "keywords",
            "conclusion",
            "background",
            "verified",
            "procedure",
            "cautions",
            "unresolved"
          ],
          "additionalProperties": false
        }
      },
      {
        "name": "totonoe-knowledge_searchKnowledge",
        "displayName": "Search Totonoe Knowledge",
        "toolReferenceName": "totonoeKnowledgeSearch",
        "canBeReferencedInPrompt": true,
        "icon": "$(search)",
        "userDescription": "ワークスペースに蓄積したプロジェクトナレッジを検索します。",
        "modelDescription": "Search the workspace's internal Markdown knowledge for existing specifications, past investigations, known issues, historical decisions, procedures, or troubleshooting cases. Use when the answer may depend on project-specific history. Return concise references; do not treat results as current without checking their status and scope.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Search terms derived from the user's question"
            },
            "limit": {
              "type": "number",
              "minimum": 1,
              "maximum": 10,
              "default": 5
            }
          },
          "required": [
            "query"
          ],
          "additionalProperties": false
        }
      }
    ],
    "configuration": {
      "title": "Totonoe Knowledge",
      "properties": {
        "totonoeKnowledge.repositoryPath": {
          "type": "string",
          "default": "knowledge",
          "description": "ワークスペースからの相対パスで指定するMarkdownナレッジ保存先"
        },
        "totonoeKnowledge.generator": {
          "type": "string",
          "enum": [
            "ask",
            "template",
            "languageModel"
          ],
          "enumDescriptions": [
            "登録時にテンプレートまたはLanguage Modelを選択する",
            "外部送信せず固定テンプレートを使用する",
            "VS Codeで選択したLanguage Modelを使用する"
          ],
          "default": "ask",
          "description": "ナレッジ案の生成方法"
        },
        "totonoeKnowledge.secretScanning.enabled": {
          "type": "boolean",
          "default": true,
          "description": "外部送信前と保存前に秘密情報らしい文字列を検査する"
        }
      }
    }
  },
  "scripts": {
    "check": "tsc --noEmit",
    "copy:sqlite-wasm": "node -e \"const fs=require('node:fs'); const path=require('node:path'); const source=path.dirname(require.resolve('sql.js/dist/sql-wasm.js')); fs.mkdirSync('dist',{recursive:true}); for(const file of ['sql-wasm.js','sql-wasm.wasm']) fs.copyFileSync(path.join(source,file),path.join('dist',file))\"",
    "compile": "esbuild ./src/extension.ts --bundle --platform=node --external:vscode --outfile=./dist/extension.js --sourcemap && npm run copy:sqlite-wasm",
    "compile:integration": "esbuild ./integration/runTest.ts ./integration/suite/index.ts --bundle --platform=node --format=cjs --external:vscode --external:@vscode/test-electron --outbase=./integration --outdir=./.integration-test --sourcemap",
    "compile:all": "npm run compile && npm run compile:integration",
    "watch": "npm run copy:sqlite-wasm && esbuild ./src/extension.ts --bundle --platform=node --external:vscode --outfile=./dist/extension.js --sourcemap --watch",
    "test": "tsx --test src/**/*.test.ts",
    "test:integration": "npm run compile:all && node ./.integration-test/runTest.js",
    "package": "npm run check && npm test && npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/sql.js": "^1.4.10",
    "@types/vscode": "^1.95.0",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.20.0",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "sql.js": "1.13.0"
  }
}
